<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Love Carts | متجر محمد البدري للهدايا ❤️</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; scroll-behavior: smooth; }
        .gradient-pink { background: linear-gradient(135deg, #db2777 0%, #f472b6 100%); }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <!-- القائمة العلوية -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <span class="text-2xl font-black text-pink-600">Love Carts ❤️</span>
            <a href="https://wa.me/201114170415 text=استفسار" class="bg-green-500 text-white px-4 py-2 rounded-full font-bold text-sm shadow-md">واتساب: 01114170415</a>
        </div>
    </nav>

    <!-- واجهة الموقع -->
    <header class="py-12 px-4 text-center bg-white border-b">
        <h1 class="text-3xl md:text-5xl font-black text-gray-900 mb-4">أجمل الهدايا في <span class="text-pink-600">عين شمس والقاهرة</span> 🇪🇬</h1>
        <p class="text-lg text-gray-500 max-w-xl mx-auto mb-6 italic text-center">بإدارة الأستاذ محمد البدري - هدايا تعبر عن مشاعرك</p>
    </header>

    <!-- نموذج الطلب السريع -->
    <section id="order-form" class="py-12 container mx-auto px-4">
        <div class="max-w-md mx-auto bg-white p-8 rounded-[2rem] shadow-2xl border border-pink-50">
            <h2 class="text-2xl font-black mb-6 text-center text-pink-600">طلب سريع عبر واتساب 🛍️</h2>
            
            <form id="whatsappForm" class="space-y-4">
                <div>
                    <label class="block mb-2 font-bold text-sm">اسمك الكريم</label>
                    <input type="text" id="name" required placeholder="أدخل اسمك" 
                           class="w-full p-4 border rounded-2xl bg-gray-50 outline-none focus:ring-2 focus:ring-pink-500">
                </div>
                
                <div>
                    <label class="block mb-2 font-bold text-sm">رقم الموبايل</label>
                    <input type="tel" id="user_phone" required placeholder="رقمك للتواصل" 
                           class="w-full p-4 border rounded-2xl bg-gray-50 outline-none focus:ring-2 focus:ring-pink-500 text-right">
                </div>
                
                <div>
                    <label class="block mb-2 font-bold text-sm">عنوان التوصيل</label>
                    <textarea id="address" required placeholder="اكتب عنوانك بالتفصيل" 
                              class="w-full p-4 border rounded-2xl bg-gray-50 outline-none focus:ring-2 focus:ring-pink-500 h-24"></textarea>
                </div>

                <button type="button" onclick="sendToWhatsApp()" 
                        class="w-full bg-[#25d366] text-white py-4 rounded-2xl font-black text-xl shadow-lg hover:bg-green-600 transition-all flex justify-center items-center gap-2">
                    تأكيد الطلب (واتساب) ✅
                </button>
            </form>
        </div>
    </section>

    <!-- تذييل الموقع ببياناتك -->
    <footer class="py-10 text-center bg-gray-100 text-gray-600">
        <p class="font-bold mb-2">محمد البدري - Love Carts</p>
        <p class="text-sm px-4">العنوان: شارع ابوالفتوح عبدالله، عين شمس الشرقية، جسر السويس، القاهرة</p>
        <p class="mt-4 text-xs">© 2024 جميع الحقوق محفوظة</p>
    </footer>

    <script>
    function sendToWhatsApp() {
        const myNumber = "201114170415"; // رقم هاتفك بصيغة دولية بدون +
        const name = document.getElementById('name').value;
        const user_phone = document.getElementById('user_phone').value;
        const address = document.getElementById('address').value;

        if(name && user_phone && address) {
            const message = "طلب جديد من متجر الحب ❤️%0A" +
                            "--------------------------%0A" +
                            "*العميل:* " + name + "%0A" +
                            "*الموبايل:* " + user_phone + "%0A" +
                            "*العنوان:* " + address + "%0A" +
                            "--------------------------%0A" +
                            "يرجى التواصل لتأكيد الطلب.";

            const whatsappURL = "https://wa.me/" + myNumber + "?text=" + message;
            window.open(whatsappURL, '_blank').focus();
        } else {
            alert("يرجى إكمال البيانات أولاً");
        }
    }
    </script>
</body>
</html>
