<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <title>لوحة الإدارة</title>
    <style>
        body { font-family: 'Cairo', sans-serif; background: #eaeded; padding: 30px; }
        .admin-box { max-width: 600px; margin: auto; background: white; padding: 25px; border-radius: 8px; box-shadow: 0 2px 15px rgba(0,0,0,0.1); }
        input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 5px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background: #232f3e; color: white; border: none; border-radius: 5px; cursor: pointer; font-size: 16px; }
        table { width: 100%; margin-top: 30px; border-collapse: collapse; background: white; }
        th, td { border: 1px solid #ddd; padding: 10px; text-align: center; }
        .delete-btn { background: #d9534f; color: white; padding: 5px 10px; border: none; border-radius: 3px; cursor: pointer; }
    </style>
</head>
<body>

<div class="admin-box">
    <h2>إضافة منتج جديد</h2>
    <input type="text" id="pName" placeholder="اسم المنتج (مثلاً: عطر عود)">
    <input type="number" id="pPrice" placeholder="السعر">
    <input type="text" id="pImage" placeholder="رابط صورة المنتج">
    <button onclick="addProduct()">إضافة المنتج للمتجر</button>
</div>

<table id="adminTable">
    <thead>
        <tr>
            <th>الصورة</th>
            <th>الاسم</th>
            <th>السعر</th>
            <th>حذف</th>
        </tr>
    </thead>
    <tbody id="tbody"></tbody>
</table>

<script>
    function displayAdminProducts() {
        const products = JSON.parse(localStorage.getItem('myProducts') || '[]');
        const tbody = document.getElementById('tbody');
        tbody.innerHTML = '';
        products.forEach((p, index) => {
            tbody.innerHTML += `
                <tr>
                    <td><img src="${p.image}" width="50"></td>
                    <td>${p.name}</td>
                    <td>${p.price}</td>
                    <td><button class="delete-btn" onclick="deleteProduct(${index})">حذف</button></td>
                </tr>
            `;
        });
    }

    function addProduct() {
        const name = document.getElementById('pName').value;
        const price = document.getElementById('pPrice').value;
        const image = document.getElementById('pImage').value;
        if(name && price && image) {
            const products = JSON.parse(localStorage.getItem('myProducts') || '[]');
            products.push({ name, price, image });
            localStorage.setItem('myProducts', JSON.stringify(products));
            location.reload();
        }
    }

    function deleteProduct(index) {
        let products = JSON.parse(localStorage.getItem('myProducts') || '[]');
        products.splice(index, 1);
        localStorage.setItem('myProducts', JSON.stringify(products));
        displayAdminProducts();
    }

    displayAdminProducts();
</script>
</body>
</html>
