<!-- قسم نموذج الطلب المرتبط بالواتساب -->
<section id="order-form" class="py-12 container mx-auto px-4">
    <div class="max-w-md mx-auto bg-white p-8 rounded-3xl shadow-lg border border-pink-100">
        <h2 class="text-2xl font-black mb-6 text-center text-gray-800">بيانات الشحن 🚚</h2>
        
        <form id="whatsappForm" class="space-y-4">
            <div>
                <label class="block mb-2 font-bold text-sm">الاسم بالكامل</label>
                <input type="text" id="name" required placeholder="مثال: أحمد محمد" 
                       class="w-full p-4 border rounded-2xl bg-gray-50 outline-none focus:ring-2 focus:ring-pink-500 transition">
            </div>
            
            <div>
                <label class="block mb-2 font-bold text-sm">رقم الموبايل</label>
                <input type="tel" id="phone" required placeholder="01XXXXXXXXX" 
                       class="w-full p-4 border rounded-2xl bg-gray-50 outline-none focus:ring-2 focus:ring-pink-500 text-left">
            </div>
            
            <div>
                <label class="block mb-2 font-bold text-sm">العنوان بالتفصيل</label>
                <textarea id="address" required placeholder="المحافظة، المنطقة، اسم الشارع" 
                          class="w-full p-4 border rounded-2xl bg-gray-50 outline-none focus:ring-2 focus:ring-pink-500 h-24"></textarea>
            </div>

            <button type="button" onclick="sendToWhatsApp()" 
                    class="w-full bg-[#25d366] text-white py-4 rounded-2xl font-black text-xl shadow-lg hover:bg-green-600 transition-all flex justify-center items-center gap-2">
                إرسال الطلب عبر واتساب 💬
            </button>
        </form>
    </div>
</section>

<script>
function sendToWhatsApp() {
    // 1. أدخل رقم واتساب الخاص بك هنا (مصحوباً بكود الدولة 20 لمصر)
    const myNumber = "201XXXXXXXXX"; 

    // 2. جلب البيانات من النموذج
    const name = document.getElementById('name').value;
    const phone = document.getElementById('phone').value;
    const address = document.getElementById('address').value;

    if(name && phone && address) {
        // 3. تجهيز نص الرسالة
        const message = "طلب جديد من Love Carts ❤️%0A" +
                        "--------------------------%0A" +
                        "*الاسم:* " + name + "%0A" +
                        "*الموبايل:* " + phone + "%0A" +
                        "*العنوان:* " + address + "%0A" +
                        "--------------------------%0A" +
                        "أرجو تأكيد الطلب المذكور أعلاه.";

        // 4. فتح رابط الواتساب
        const whatsappURL = "https://wa.me/" + myNumber + "?text=" + message;
        window.open(whatsappURL, '_blank').focus();
    } else {
        alert("يرجى ملء جميع البيانات أولاً");
    }
}
</script>
